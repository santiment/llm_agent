# Any OpenAI-compatible endpoint. Default is OpenRouter (model-agnostic).
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-...

# Web search
TAVILY_API_KEY=tvly-...

# Models: pick a named price package — extra-low | low | mid | high (MODEL_TIERS in
# config.py; see README "Model tiers"). Sets all three model slots together.
# Default when unset: extra-low (cheapest; fine for trying things out, weak for real
# research — opt up for real work). This is the ONLY model knob: individual models
# are deliberately not settable per env var or per run — to change which models a
# tier means, edit MODEL_TIERS in code (one reviewed place).
DRA_MODEL_TIER=mid

# Single server: DRA_MCP_URL (+ optional DRA_MCP_LABEL for the Sources name).
DRA_MCP_URL=http://127.0.0.1:8765
DRA_MCP_LABEL=
# Multiple servers: DRA_MCP_SERVERS:
# DRA_MCP_SERVERS=[{"label":"Data MCP","url":"http://127.0.0.1:8765/mcp"},{"label":"Another Data MCP","url":"http://127.0.0.1:8766/mcp"}]

# Code-execution sandbox sidecar (llm_sandbox). The agent is the caller: it sends
# LLM_SANDBOX_TOKEN as `Authorization: Bearer` to LLM_SANDBOX_URL. The token MUST equal the
# sandbox service's LLM_SANDBOX_TOKEN (empty on both = auth disabled, for local dev).
# Consumed once the SandboxBackend is wired in — see projects/llm_sandbox/README.md.
LLM_SANDBOX_URL=http://127.0.0.1:8900
LLM_SANDBOX_TOKEN=

# Native social_messages tool (drop-in from custom_tools/). Direct POST to
# metrics-hub /sample_documents — unset = tool not loaded. DRA_SAMPLE_MAX_WORDS is the
# sampled-text budget in WORDS the tool requests (metrics-hub's `max_words` param); the
# server clamps it to its own ceiling (400k words). Large samples are offloaded to a
# sandbox file and processed with `execute`.
DRA_METRICS_HUB_URL=http://localhost:3000
DRA_SAMPLE_MAX_WORDS=100000
